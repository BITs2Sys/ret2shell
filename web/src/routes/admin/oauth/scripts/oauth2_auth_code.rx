//! * oauth2_auth_code.rx
//! * OAuth2 授权码模式认证
//  * reference: https://auth0.com/docs/get-started/authentication-and-authorization-flow/authorization-code-flow#how-authorization-code-flow-works

/// 获取 access token 的 URL
const AUTH_SERVER_URL = "https://example.com/login/oauth/access_token";
/// 通过 access token 获取用户信息的 URL
const DATA_SERVER_URL = "https://api.example.com/user";
/// OAuth2 client ID 和 secret
const CLIENT_ID = "";
const CLIENT_SECRET = "";

/// 使用 OAuth2 授权码模式登录
///
/// [endpoint] ${API}/account/oauth/login
///
/// * params: the request parameters
///
/// Returns: Result<#{ auth_key: string, [key: string]: string }, any>
///  * auth_key: the unique key for this user
pub async fn login(params) {
    let code = params.get("code")?;
    let client = http::Client::new();
    let token_resp = client.post(AUTH_SERVER_URL)
                           .header("Accept", "application/json")
                           .header("Content-Type", "application/json")
                           .body_bytes(json::to_bytes(#{
                               client_id: CLIENT_ID,
                               client_secret: CLIENT_SECRET,
                               code: code,
                               state: "N0T_1MP0RT4NT",
                           })?).send().await?.json().await?;
    let token = token_resp.access_token;
    let user = client.get(DATA_SERVER_URL)
                     .header("Accept", "application/json")
                     .header("User-Agent", "ret2shell/3")
                     .header("Authorization", `Bearer ${token}`)
                     .send().await?;
    let user = user.json().await?;
    Ok(#{
        auth_key: user.login.clone(),
        login: user.login,
    })
}

/// 将用户与组织绑定
///
/// [endpoint] ${API}/account/oauth/bind
///
/// * params: the request parameters
/// * user: user data of who requested this bind
///
/// Returns: Result<#{ auth_key: string, [key: string]: string }, any>
pub async fn bind(params, user) {
    Ok(login(params).await?)
}

